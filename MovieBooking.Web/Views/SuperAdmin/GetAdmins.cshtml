@using System.Linq
@model List<MovieBooking.Web.ApiContracts.Admin.AdminDto>

@{
    ViewData["Title"] = "Admins";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">👑 Admins</h2>
            <small class="text-muted">Manage platform admins</small>
        </div>

        <a asp-action="CreateAdmin" class="btn btn-primary fw-semibold">
            <i class="bi bi-plus-lg"></i> Create Admin
        </a>
    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ERROR MESSAGE -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- EMPTY STATE -->
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            No admins found.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var admin in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">

                            <!-- ADMIN INFO -->
                            <h5 class="fw-bold mb-1">@admin.Name</h5>
                            <small class="text-muted">@admin.Email</small>

                            <!-- STATUS -->
                            <div class="mt-2">
                                @if (admin.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>

                            <!-- ACTIONS -->
                            <div class="mt-auto pt-3">
                                <form asp-action="DeleteAdmin" method="post">
                                    <input type="hidden" name="id" value="@admin.UserId" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger w-100"
                                            @(admin.IsActive ? "" : "disabled")>
                                        Deactivate
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
