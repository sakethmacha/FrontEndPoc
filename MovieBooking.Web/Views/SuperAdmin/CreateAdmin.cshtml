@model MovieBooking.Web.ViewModels.AddAdminViewModel

@{
    ViewData["Title"] = "Create Admin";
}

<div class="container-fluid vh-100 d-flex justify-content-center align-items-center">
    <div class="col-md-6 col-lg-5">
        <div class="card auth-card p-4">

            <div class="text-center mb-4">
                <h3 class="fw-bold">
                    <i class="bi bi-shield-lock me-2"></i>Create Admin
                </h3>
                <p class="text-muted mb-0">
                    Create a new admin account
                </p>
            </div>

            <form asp-action="CreateAdmin" method="post" novalidate>
                <partial name="_UserForm" model="Model" />

                <button type="submit"
                        class="btn btn-success w-100 py-2 fw-semibold">
                    Create Admin
                </button>
            </form>

            <hr class="my-4" />

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/custom-validators.js"></script>
}
