@{
    ViewData["Title"] = "Movie Booking";
}

<div class="container mt-4">

    <!-- HERO SECTION -->
    <div class="row mb-5">
        <div class="col text-center">
            <h1 class="display-4 fw-bold">
                🎬 Movie Booking System
            </h1>
            <p class="lead text-muted mt-3">
                Book your favorite movies, choose your seats, and enjoy a seamless cinema experience.
            </p>
        </div>
    </div>

    <!-- FEATURES SECTION -->
    <div class="row text-center mb-5">

        <div class="col-md-4 mb-3">
            <div class="p-4 border rounded-4 h-100 bg-light">
                <div class="display-5">🎥</div>
                <h5 class="fw-bold mt-3">Latest Movies</h5>
                <p class="text-muted">
                    Stay updated with newly released movies across all genres.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="p-4 border rounded-4 h-100 bg-light">
                <div class="display-5">💺</div>
                <h5 class="fw-bold mt-3">Seat Selection</h5>
                <p class="text-muted">
                    View seating layouts and select seats based on availability.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="p-4 border rounded-4 h-100 bg-light">
                <div class="display-5">💳</div>
                <h5 class="fw-bold mt-3">Secure Payments</h5>
                <p class="text-muted">
                    Payments are processed quickly and securely.
                </p>
            </div>
        </div>

    </div>

    <!-- INFO SECTION -->
    <div class="row mt-4">
        <div class="col text-center">
            <div class="alert alert-secondary">
                🎟️ This system allows users to explore movies, select showtimes, choose seats,
                and complete bookings efficiently.
            </div>
        </div>
    </div>

</div>
