@model MovieBooking.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: linear-gradient(135deg, #141e30, #243b55);
    }

    .auth-card {
        border-radius: 18px;
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.95);
        box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        border: none;
    }

    .input-group-text {
        background: #f4f6f9;
        border: none;
    }

    .form-control {
        border-left: none;
    }

    .register-btn {
        background: linear-gradient(135deg, #ff416c, #ff4b2b);
        border: none;
    }
</style>

<div class="container-fluid vh-100 d-flex justify-content-center align-items-center">
    <div class="col-md-6 col-lg-5">
        <div class="card auth-card p-4">

            <div class="text-center mb-4">
                <h3 class="fw-bold">🎬 Create Your Account</h3>
                <p class="text-muted mb-0">
                    Join us and start booking movies instantly
                </p>
            </div>

            <form asp-action="Register" method="post" novalidate>
                <partial name="_UserForm" model="Model" />

                <button type="submit"
                        class="btn register-btn w-100 py-2 fw-semibold text-white">
                    Create Account
                </button>
            </form>

            <hr class="my-4" />

            <p class="text-center mb-0">
                Already have an account?
                <a asp-action="Login" class="fw-semibold text-decoration-none">
                    Login here
                </a>
            </p>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(el) {
            const input = el.parentElement.querySelector(".password-input");
            const icon = el.querySelector("i");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }
    </script>
}
