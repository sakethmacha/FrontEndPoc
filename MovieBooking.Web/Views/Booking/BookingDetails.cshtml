@using MovieBooking.Web.Enums;
@model MovieBooking.Web.ApiContracts.Booking.BookingConfirmationResponse
@{
    ViewData["Title"] = "Booking Details";
    var isPastShow = Model.Theatre.ShowTime < DateTime.Now;
    var canCancel = Model.Status == "CONFIRMED" && Model.Theatre.ShowTime > DateTime.Now.AddHours(2);
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <!-- Header with Back Button -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2><i class="bi bi-ticket-detailed-fill"></i> Booking Details</h2>
                    <p class="text-muted mb-0">Reference: <strong>@Model.BookingReference</strong></p>
                </div>
                <a href="@Url.Action("Bookings")" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to My Bookings
                </a>
            </div>

            <!-- Main Ticket Card -->
            <div class="card shadow-lg border-0 mb-4">

                <!-- Card Header with Status -->
                <div class="card-header py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="row align-items-center text-white">
                        <div class="col-md-8">
                            <h4 class="mb-1">@Model.Movie.Title</h4>
                            <p class="mb-0">
                                <span class="badge bg-light text-dark me-2">@Model.Movie.Language</span>
                                <span class="badge bg-light text-dark">@Model.Movie.DurationMinutes mins</span>
                            </p>
                        </div>
                        <div class="col-md-4 text-md-end">
                            @{
                                var statusBadgeClass = Model.Status switch
                                {
                                   "CONFIRMED" => "bg-success",
                                    "PENDING" => "bg-warning text-dark",
                                    "CANCELLED" => "bg-secondary",
                                   "FAILED" => "bg-danger",
                                    _ => "bg-info"
                                };
                            }
                            <h5 class="mb-0">
                                <span class="badge @statusBadgeClass fs-6">@Model.Status</span>
                            </h5>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">

                    <!-- Show Status Alert -->
                    @if (isPastShow)
                    {
                        <div class="alert alert-secondary">
                            <i class="bi bi-clock-history"></i> This show has ended
                        </div>
                    }
                    else if (Model.Status == "CANCELLED")
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-x-circle"></i> This booking has been cancelled. Refund will be processed within 5-7 business days.
                        </div>
                    }       
                    else if (Model.Status == "CONFIRMED")
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i> Your booking is confirmed. See you at the movies!
                        </div>
                    }

                    <!-- Theatre and Show Information -->
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="info-card">
                                <h6 class="text-muted text-uppercase mb-3">
                                    <i class="bi bi-building"></i> Theatre Information
                                </h6>
                                <div class="mb-2">
                                    <strong>Theatre:</strong>
                                    <p class="mb-0">@Model.Theatre.Name</p>
                                </div>
                                <div class="mb-2">
                                    <strong>Location:</strong>
                                    <p class="mb-0">
                                        <i class="bi bi-geo-alt-fill text-danger"></i> @Model.Theatre.Location
                                    </p>
                                </div>
                                <div>
                                    <strong>Screen:</strong>
                                    <p class="mb-0">@Model.Theatre.ScreenName</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <h6 class="text-muted text-uppercase mb-3">
                                    <i class="bi bi-calendar-event"></i> Show Information
                                </h6>
                                <div class="mb-2">
                                    <strong>Date:</strong>
                                    <p class="mb-0">@Model.Theatre.ShowTime.ToString("dddd, dd MMMM yyyy")</p>
                                </div>
                                <div class="mb-2">
                                    <strong>Time:</strong>
                                    <p class="mb-0">@Model.Theatre.ShowTime.ToString("hh:mm tt")</p>
                                </div>
                                <div>
                                    <strong>Language:</strong>
                                    <p class="mb-0">@Model.Movie.Language</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Seats Details -->
                    <div class="mb-4">
                        <h5 class="mb-3">
                            <i class="bi bi-person-fill-check"></i> Booked Seats (@Model.Seats.Count)
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th width="20%">Seat Number</th>
                                        <th width="40%">Seat Type</th>
                                        <th width="40%" class="text-end">Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var seat in Model.Seats)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-success fs-6">@seat.SeatNumber</span>
                                            </td>
                                            <td>
                                                @{
                                                    var seatTypeBadge = seat.SeatType switch
                                                    {
                                                        "VIP" => "bg-warning text-dark",
                                                        "RECLINER" => "bg-danger",
                                                        _ => "bg-primary"
                                                    };
                                                }
                                                <span class="badge @seatTypeBadge">@seat.SeatType</span>
                                            </td>
                                            <td class="text-end">₹@seat.Price.ToString("F2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr class="fw-bold">
                                        <td colspan="2">Total Amount</td>
                                        <td class="text-end text-success fs-5">₹@Model.TotalAmount.ToString("F2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- Booking Timeline -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <h6 class="mb-3">
                                <i class="bi bi-clock-history"></i> Booking Timeline
                            </h6>
                            <div class="timeline">
                                <div class="timeline-item">
                                    <i class="bi bi-circle-fill text-success"></i>
                                    <strong>Booking Created:</strong> @Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                                </div>
                                @if (Model.Status == "CONFIRMED")
                                {
                                    <div class="timeline-item">
                                        <i class="bi bi-circle-fill text-success"></i>
                                        <strong>Payment Confirmed:</strong> @Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- QR Code / Barcode -->
                    <div class="text-center py-4 bg-light rounded mb-4">
                        <h6 class="text-muted mb-3">Present this at Theatre Counter</h6>
                        <div class="d-inline-block bg-white p-4 border rounded shadow-sm">
                            <div class="mb-3">
                                <i class="bi bi-qr-code" style="font-size: 150px; color: #333;"></i>
                            </div>
                            <div class="mb-2">
                                <strong class="font-monospace fs-5">@Model.BookingReference</strong>
                            </div>
                            <small class="text-muted">Scan or show this code</small>
                        </div>
                    </div>

                    <!-- Important Information -->
                    <div class="alert alert-info border-info">
                        <h6 class="alert-heading">
                            <i class="bi bi-info-circle-fill"></i> Important Guidelines
                        </h6>
                        <hr>
                        <div class="row">
                            <div class="col-md-6">
                                <ul class="mb-0">
                                    <li>Arrive 15-20 minutes before show time</li>
                                    <li>Carry a valid government photo ID</li>
                                    <li>Entry allowed only with valid ticket</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="mb-0">
                                    <li>Outside food & beverages not allowed</li>
                                    <li>Follow theatre rules and regulations</li>
                                    <li>Ticket non-transferable</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Cancellation Policy -->
                    @if (canCancel)
                    {
                        <div class="alert alert-warning border-warning">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-triangle-fill"></i> Cancellation Policy
                            </h6>
                            <p class="mb-0">
                                You can cancel this booking up to 2 hours before the show time.
                                Refund will be processed within 5-7 business days.
                            </p>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="row g-3 mt-2">
                        <div class="col-md-3">
                            <button class="btn btn-primary w-100" onclick="window.print()">
                                <i class="bi bi-printer-fill"></i> Print Ticket
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-primary w-100" onclick="downloadTicket()">
                                <i class="bi bi-download"></i> Download PDF
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-secondary w-100" onclick="shareTicket()">
                                <i class="bi bi-share-fill"></i> Share
                            </button>
                        </div>
                        @if (canCancel)
                        {
                            <div class="col-md-3">
                                <button class="btn btn-outline-danger w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#cancelModal">
                                    <i class="bi bi-x-circle"></i> Cancel Booking
                                </button>
                            </div>
                        }
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- Cancel Booking Modal -->
@if (canCancel)
{
    <div class="modal fade" id="cancelModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="CancelBooking" method="post">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">
                            <i class="bi bi-exclamation-triangle-fill"></i> Cancel Booking
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="bookingId" value="@Model.BookingId" />

                        <div class="alert alert-warning">
                            <strong>Are you sure you want to cancel this booking?</strong>
                            <p class="mb-0 mt-2">Booking Reference: <strong>@Model.BookingReference</strong></p>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Reason for Cancellation (Optional)</label>
                            <textarea class="form-control" name="reason" rows="3"
                                  placeholder="Please tell us why you're cancelling..."></textarea>
                        </div>

                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="mb-2">Refund Details</h6>
                                <p class="mb-1 small">Amount to be refunded: <strong>₹@Model.TotalAmount.ToString("F2")</strong></p>
                                <p class="mb-0 small text-muted">Refund will be processed to original payment method within 5-7 business days</p>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Keep Booking
                        </button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-check-circle"></i> Confirm Cancellation
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .info-card {
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 8px;
        height: 100%;
    }

    .timeline {
        position: relative;
        padding-left: 30px;
    }

    .timeline-item {
        position: relative;
        padding-bottom: 15px;
    }

        .timeline-item i {
            position: absolute;
            left: -30px;
            font-size: 10px;
        }

    @@media print {
        .btn, .alert-warning, .alert-info, nav, footer {
            display: none !important;
        }

        .card {
            border: 2px solid #000 !important;
            box-shadow: none !important;
        }
    }
</style>

@section Scripts {
    <script>
        function downloadTicket() {
            // In production, integrate with PDF generation library
            alert('Ticket download will be available soon. You can print the ticket for now.');
        }

        function shareTicket() {
            const shareData = {
                title: 'Movie Ticket - @Model.Movie.Title',
                text: 'Booking Reference: @Model.BookingReference\n@Model.Theatre.Name\n@Model.Theatre.ShowTime.ToString("dd MMM yyyy, hh:mm tt")',
                url: window.location.href
            };

            if (navigator.share) {
                navigator.share(shareData)
                    .then(() => console.log('Shared successfully'))
                    .catch((error) => console.log('Error sharing', error));
            } else {
                // Fallback: Copy to clipboard
                navigator.clipboard.writeText(
                    `Movie Ticket\nBooking: @Model.BookingReference\n@Model.Movie.Title\n@Model.Theatre.Name\n@Model.Theatre.ShowTime.ToString("dd MMM yyyy, hh:mm tt")\nSeats: @string.Join(", ", Model.Seats.Select(s => s.SeatNumber))`
                );
                alert('Booking details copied to clipboard!');
            }
        }
    </script>
}