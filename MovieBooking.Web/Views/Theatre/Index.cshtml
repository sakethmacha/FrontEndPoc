@model List<MovieBooking.Web.ApiContracts.Theatres.TheatreResponse>

@{
    ViewData["Title"] = "Theatres";
}

<style>
    .theatre-card {
        border-radius: 18px;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        border: none;
    }

        .theatre-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 35px rgba(0,0,0,0.12);
        }

    .theatre-title {
        font-weight: 600;
        font-size: 1.05rem;
    }

    .theatre-meta {
        font-size: 0.9rem;
        color: #6c757d;
    }

    .status-badge {
        font-size: 0.8rem;
        padding: 6px 10px;
        border-radius: 12px;
    }

    .empty-state {
        border: 2px dashed #dee2e6;
        border-radius: 18px;
        padding: 40px;
        text-align: center;
        background-color: #fafafa;
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-building me-2"></i>Theatres
            </h2>
            <small class="text-muted">Manage theatres and their screens</small>
        </div>

        <div>
            <a asp-action="AddTheatre" class="btn btn-primary fw-semibold">
                <i class="bi bi-plus-lg"></i> Add Theatre
            </a>
            <a asp-action="AddScreen" class="btn btn-outline-secondary fw-semibold ms-2">
                <i class="bi bi-layout-split"></i> Add Screen
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <!-- EMPTY STATE -->
        <div class="empty-state shadow-sm">
            <h5 class="fw-bold">No Theatres Available</h5>
            <p class="text-muted mb-3">
                Add theatres to start managing screens and showtimes.
            </p>
            <a asp-action="AddTheatre" class="btn btn-outline-primary">
                <i class="bi bi-plus-circle me-2"></i> Add Theatre
            </a>
        </div>
    }
    else
    {
        <!-- THEATRE CARDS -->
        <div class="row g-4">
            @foreach (var t in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card theatre-card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">

                            <!-- TITLE & STATUS -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="theatre-title">
                                    <i class="bi bi-building text-muted me-1"></i>
                                    @t.Name
                                </div>

                                @if (t.IsActive)
                                {
                                    <span class="badge bg-success status-badge">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger status-badge">
                                        Inactive
                                    </span>
                                }
                            </div>

                            <!-- META -->
                            <div class="theatre-meta mb-3">
                                <i class="bi bi-geo-alt"></i>
                                @t.Location
                            </div>

                            <!-- ACTIONS -->
                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="EditTheatre"
                                   asp-route-id="@t.TheatreId"
                                   class="btn btn-sm btn-outline-primary flex-fill">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                                <a asp-controller="Screen" asp-action="GetScreensByTheatre"
                                   asp-route-theatreId="@t.TheatreId"
                                   class="btn btn-sm btn-outline-secondary flex-fill">
                                    <i class="bi bi-tv"></i> Screens
                                </a>

                                <button type="button"
                                        class="btn btn-sm btn-outline-danger flex-fill"
                                        onclick="confirmDelete('@t.TheatreId', '@t.Name')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>


                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="theatreName"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(theatreId, theatreName) {
            document.getElementById('theatreName').textContent = theatreName;
            document.getElementById('deleteForm').action = '/Theatre/DeleteTheatre/' + theatreId;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
}