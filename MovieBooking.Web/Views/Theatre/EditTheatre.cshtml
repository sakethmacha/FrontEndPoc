@model MovieBooking.Web.ViewModels.AddTheatreViewModel

@{
    ViewData["Title"] = "Edit Theatre";
    var theatreId = ViewBag.TheatreId;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Edit Theatre
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditTheatre" asp-route-id="@theatreId" method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Theatre Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter theatre name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-semibold">Location</label>
                            <input asp-for="Location" class="form-control" placeholder="Enter location" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Theatre Time Slots</label>
                            <div id="timeSlotsContainer">
                                <!-- Time slots will be added here dynamically -->
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="addTimeSlot()">
                                <i class="bi bi-plus-lg"></i> Add Time Slot
                            </button>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-check-lg"></i> Update Theatre
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-x-lg"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let slotIndex = 0;

        function addTimeSlot(startTime = '', endTime = '') {
            const container = document.getElementById('timeSlotsContainer');
            const div = document.createElement('div');
            div.className = 'row mb-2';
            div.innerHTML = `
                <div class="col-5">
                    <input type="time" name="TimeSlots[${slotIndex}].StartTime" class="form-control" value="${startTime}" required />
                </div>
                <div class="col-5">
                    <input type="time" name="TimeSlots[${slotIndex}].EndTime" class="form-control" value="${endTime}" required />
                </div>
                <div class="col-2">
                    <button type="button" class="btn btn-sm btn-danger w-100" onclick="this.parentElement.parentElement.remove()">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            `;
            container.appendChild(div);
            slotIndex++;
        }

        // Add at least one time slot on load
        window.addEventListener('DOMContentLoaded', () => {
            addTimeSlot();
        });
    </script>
}