@model MovieBooking.Web.ViewModels.Admin.RequestScreenViewModel

@{
    ViewData["Title"] = "Request Screen";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle"></i> Request New Screen
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="RequestScreen" method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TheatreId" class="form-label fw-semibold">Theatre</label>
                                <select asp-for="TheatreId" class="form-select" required>
                                    <option value="">-- Select Theatre --</option>
                                    @foreach (var theatre in Model.AvailableTheatres)
                                    {
                                        <option value="@theatre.TheatreId">@theatre.Name - @theatre.Location</option>
                                    }
                                </select>
                                <span asp-validation-for="TheatreId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ScreenName" class="form-label fw-semibold">Screen Name</label>
                                <input asp-for="ScreenName" class="form-control" placeholder="Screen 1" required />
                                <span asp-validation-for="ScreenName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SeatLayoutType" class="form-label fw-semibold">Seat Layout Type</label>
                            <select asp-for="SeatLayoutType" class="form-select" required>
                                <option value="">-- Select Layout --</option>
                                <option value="Standard">Standard</option>
                                <option value="Premium">Premium</option>
                                <option value="IMAX">IMAX</option>
                            </select>
                            <span asp-validation-for="SeatLayoutType" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Seat Rows Configuration</label>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Row</th>
                                            <th>Seats</th>
                                            <th>Type</th>
                                            <th>Price Multiplier</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="seatRowsContainer"></tbody>
                                </table>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addSeatRow()">
                                <i class="bi bi-plus-lg"></i> Add Seat Row
                            </button>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="bi bi-send"></i> Submit Request
                            </button>
                            <a asp-action="MyScreens" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-x-lg"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let rowIndex = 0;

        function addSeatRow() {
            const container = document.getElementById('seatRowsContainer');
            const tr = document.createElement('tr');

            tr.innerHTML = `
                <td>
                    <input type="text"
                           name="SeatRows[${rowIndex}].SeatRow"
                           class="form-control form-control-sm"
                           placeholder="A"
                           required />
                </td>
                <td>
                    <input type="number"
                           name="SeatRows[${rowIndex}].SeatCount"
                           class="form-control form-control-sm"
                           placeholder="10"
                           min="1"
                           required />
                </td>
                <td>
                    <select name="SeatRows[${rowIndex}].SeatType"
                            class="form-select form-select-sm"
                            required>
                        <option value="">-- Select --</option>
                        <option value="NORMAL">Normal</option>
                        <option value="VIP">VIP</option>
                        <option value="RECLINER">Recliner</option>
                    </select>
                </td>
                <td>
                    <input type="number"
                           name="SeatRows[${rowIndex}].PriceMultiplier"
                           class="form-control form-control-sm"
                           step="0.1"
                           value="1.0"
                           required />
                </td>
                <td>
                    <button type="button"
                            class="btn btn-sm btn-danger"
                            onclick="this.closest('tr').remove()">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            `;

            container.appendChild(tr);
            rowIndex++;
        }

        window.addEventListener('DOMContentLoaded', () => {
            addSeatRow();
        });
    </script>
    }