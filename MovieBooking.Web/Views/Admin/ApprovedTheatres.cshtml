@model List<MovieBooking.Web.ApiContracts.Admin.TheatreRequestResponse>

@{
    ViewData["Title"] = "Approved Theatres";
}

<style>
    .theatre-card {
        border-radius: 18px;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        border: none;
    }

        .theatre-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 35px rgba(0,0,0,0.12);
        }

    .theatre-title {
        font-weight: 600;
        font-size: 1.05rem;
    }

    .theatre-meta {
        font-size: 0.9rem;
        color: #6c757d;
    }

    .timeslot-badge {
        background-color: #e3f2fd;
        color: #1976d2;
        padding: 4px 8px;
        border-radius: 8px;
        font-size: 0.85rem;
        margin-right: 4px;
        margin-bottom: 4px;
        display: inline-block;
    }

    .empty-state {
        border: 2px dashed #dee2e6;
        border-radius: 18px;
        padding: 60px;
        text-align: center;
        background-color: #fafafa;
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"> My Approved Theatres</h2>
            <small class="text-muted">Theatres approved by SuperAdmin</small>
        </div>

        <div class="btn-group">
            <a asp-action="MyTheatres" class="btn btn-outline-secondary">
                <i class="bi bi-list"></i> All Requests
            </a>
            <a asp-action="RequestTheatre" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Request New Theatre
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- EMPTY STATE -->
        <div class="empty-state shadow-sm">
            <i class="bi bi-building" style="font-size: 4rem; color: #ccc;"></i>
            <h5 class="fw-bold mt-3">No Approved Theatres Yet</h5>
            <p class="text-muted mb-3">
                Your theatre requests are pending approval or haven't been submitted yet.
            </p>
            <div class="d-flex gap-2 justify-content-center">
                <a asp-action="MyTheatres" class="btn btn-outline-primary">
                    <i class="bi bi-list"></i> View All Requests
                </a>
                <a asp-action="RequestTheatre" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Request Theatre
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- APPROVED THEATRES CARDS -->
        <div class="row g-4">
            @foreach (var theatre in Model)
            {
                <div class="col-xl-4 col-lg-6">
                    <div class="card theatre-card shadow-sm h-100">
                        <div class="card-body">

                            <!-- TITLE & BADGE -->
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="theatre-title">
                                    <i class="bi bi-building text-success me-2"></i>
                                    @theatre.Name
                                </div>
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Approved
                                </span>
                            </div>

                            <!-- LOCATION -->
                            <div class="theatre-meta mb-3">
                                <i class="bi bi-geo-alt text-primary"></i>
                                @theatre.Location
                            </div>

                            <!-- REQUESTED DATE -->
                            <div class="theatre-meta mb-3">
                                <i class="bi bi-calendar-event"></i>
                                Approved: @theatre.RequestedAt.ToString("dd MMM yyyy")
                            </div>

                            <!-- TIME SLOTS -->
                            @if (theatre.TimeSlots.Any())
                            {
                                <div class="mt-3">
                                    <strong class="small d-block mb-2">
                                        <i class="bi bi-clock"></i> Show Time Slots:
                                    </strong>
                                    <div>
                                        @foreach (var slot in theatre.TimeSlots)
                                        {
                                            <span class="timeslot-badge">
                                                @slot.StartTime - @slot.EndTime
                                            </span>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- ACTIONS -->
                            <div class="mt-4 pt-3 border-top">
                                <a asp-action="RequestScreen"
                                   class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-plus-lg"></i> Add Screen to This Theatre
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- INFO BOX -->
        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle"></i>
            <strong>Total Approved Theatres:</strong> @Model.Count
        </div>
    }
</div>